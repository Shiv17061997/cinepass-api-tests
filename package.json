{
  "name": "cinepass-api-tests",
  "version": "1.1.0",
  "description": "Complete Playwright API test automation for CinePass Backend API with Allure reporting - Now with Admin Authorization Testing",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test tests/auth.spec.js",
    "test:admin": "playwright test tests/admin.spec.js",
    "test:movies": "playwright test tests/movies.spec.js",
    "test:showtimes": "playwright test tests/showtimes.spec.js",
    "test:bookings": "playwright test tests/bookings.spec.js",
    "test:debug": "playwright test --debug",
    "allure:serve": "allure serve allure-results",
    "allure:report": "allure generate allure-results -o allure-report --clean"
  },
  "keywords": [
    "playwright",
    "api-testing",
    "allure",
    "jest",
    "cinepass",
    "admin-authorization",
    "rbac"
  ],
  "author": "Shiv17061997",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "allure-commandline": "^2.25.0",
    "allure-playwright": "^2.12.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
